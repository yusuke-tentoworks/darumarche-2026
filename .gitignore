# .gitignore - Gitの管理から除外するファイルの設定

# 依存関係 (Dependencies)
node_modules/
/jspm_packages/
lib-cov/
.grunt
.lock-wscript
package-lock.json
yarn.lock
pnpm-lock.yaml

# 環境変数・機密情報 (Environment Variables & Secrets)
.env
.env.test
.env.production
.env.local
.env.*.local
*.key
*.pem
.node_repl_history

# ビルド成果物 (Build Artifacts)
dist/
build/
bin/
obj/
out/
.next/
.nuxt/
.cache/
.parcel-cache/

# OS固有のファイル (OS Specific Files)
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE / エディタ設定 (Editor Settings)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ログファイル (Logs)
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# テスト成果物 (Test Results)
coverage/
.nyc_output/

# その他 (Others)
.aiignore
